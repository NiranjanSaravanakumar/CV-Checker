# ─── Backend ───────────────────────────────────────
# Required: Get this from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyAXDTL966-tyTxdi9tt9WncwwTjz3GUkls

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-this-to-a-long-random-string

# Database (SQLite default, or use PostgreSQL for production)
# For SQLite: sqlite:///resumes.db
# For PostgreSQL: postgresql://user:password@host/dbname
DATABASE_URL=sqlite:///resumes.db

# CORS – comma-separated allowed origins (no trailing slash)
CORS_ORIGINS=http://localhost:5173

# Flask debug mode (set to False in production)
FLASK_DEBUG=True

# Port (default 5000)
PORT=5000

# ─── Frontend ──────────────────────────────────────
# Set to your Render backend URL for production deployment
# Leave empty to use Vite proxy in development
VITE_API_URL=
